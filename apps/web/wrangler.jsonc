{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "u-tube",
	"compatibility_date": "2025-09-02",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"main": "@tanstack/react-start/server-entry",
	"queues": {
		"producers": [
			{
				"queue": "container-jobs",
				"binding": "container_jobs"
			}
		]
	},
	"r2_buckets": [
		{
			"bucket_name": "temp-video",
			"binding": "temp_video"
		},
		{
			"bucket_name": "temp-image",
			"binding": "temp_image"
		}
	]
}